---
import "katex/dist/katex.min.css";
import "../styles/global.css";
import Comments from "../components/Comments.astro";
import SiteSocialLinks from "../components/SiteSocialLinks.astro";

interface Props {
  title?: string;
  description?: string;
  /** 仅文章页开启：文末 Utterances */
  comments?: boolean;
}

const {
  title = "Yu's Blog",
  description = "记录思考与专业成长的个人博客",
  comments = false,
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isHome = pathname === "/";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <!-- 夜间预览：/?theme=dark 保持本站深色直到 ?theme=light（sessionStorage） -->
    <script is:inline>
      (function () {
        try {
          var q = new URLSearchParams(location.search).get("theme");
          if (q === "dark") {
            document.documentElement.setAttribute("data-theme", "dark");
            sessionStorage.setItem("blog-theme-preview", "dark");
          } else if (q === "light") {
            document.documentElement.removeAttribute("data-theme");
            sessionStorage.removeItem("blog-theme-preview");
          } else if (sessionStorage.getItem("blog-theme-preview") === "dark") {
            document.documentElement.setAttribute("data-theme", "dark");
          }
        } catch (e) {}
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" type="image/x-icon" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- 免费 Web 备用：与正文/标题/界面方案气质接近（衬线阅读 + 展示 + 无衬线 UI） -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=JetBrains+Mono:wght@400;500;600&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Noto+Sans+SC:wght@400;500;600;700&family=Noto+Serif+SC:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Source+Serif+4:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />

  </head>
  <body>
    <!-- 阅读进度条 -->
    <div id="reading-progress"></div>

    <div class="page-grid">
      <main class="paper">
        <slot />
        {comments && <Comments />}
      </main>
    </div>

    {!isHome && <SiteSocialLinks variant="floating" />}

    <!-- 阅读进度条脚本 -->
    <script>
      function updateProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        const bar = document.getElementById('reading-progress');
        if (bar) bar.style.width = progress + '%';
      }

      window.addEventListener('scroll', updateProgress, { passive: true });
      window.addEventListener('load', updateProgress);

      // 支持 Astro View Transitions
      document.addEventListener('astro:after-swap', () => {
        updateProgress();
      });
    </script>
  </body>
</html>
