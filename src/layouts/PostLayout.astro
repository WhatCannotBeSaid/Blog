---
import Layout from './Layout.astro';
const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title} description={frontmatter.description} comments>
  <article class="prose">
    <header class="post-header">
      <h1>{frontmatter.title}</h1>
      {frontmatter.date && <time>{frontmatter.date}</time>}
    </header>
    <slot />
  </article>
</Layout>

<style>
  .post-header {
    margin-bottom: 0.5rem;
  }

  .post-header:not(:has(time)) {
    margin-bottom: 2.5rem;
  }

  .post-header h1 {
    margin-bottom: 0.5rem;
  }

  .post-header time {
    font-family: var(--title-font);
    font-size: 1.05rem;
    color: var(--ink-faint);
  }

  .prose {
    /* 文章内容排版 */
  }

  /* 标题段距见 global.css article.prose（学术论文体例） */

  /* KaTeX 公式间距 */
  .prose :global(.katex-display) {
    margin: 1.5rem 0;
    overflow-x: auto;
  }
</style>
